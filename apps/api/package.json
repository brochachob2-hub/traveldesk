{
  "name": "@traveldesk/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "migrate:deploy": "npx prisma migrate deploy --schema=../../packages/database/prisma/schema.prisma",
    "start:migrate": "npx prisma migrate deploy --schema=../../packages/database/prisma/schema.prisma && node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@traveldesk/database": "*",
    "@nestjs/common": "latest",
    "@nestjs/config": "latest",
    "@nestjs/core": "latest",
    "@nestjs/jwt": "latest",
    "@nestjs/platform-fastify": "latest",
    "@nestjs/throttler": "latest",
    "@nestjs/schedule": "latest",
    "@fastify/cookie": "latest",
    "bcryptjs": "latest",
    "class-transformer": "latest",
    "class-validator": "latest",
    "reflect-metadata": "latest",
    "rxjs": "latest"
  },
  "devDependencies": {
    "@nestjs/cli": "latest",
    "@nestjs/testing": "latest",
    "@types/jest": "latest",
    "@types/node": "latest",
    "jest": "latest",
    "ts-jest": "latest",
    "ts-node": "latest",
    "typescript": "latest"
  }
}
